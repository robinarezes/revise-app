# Copie ce fichier en .env.local pour le dev local, ou configure ces
# variables dans Vercel (Project Settings > Environment Variables).

# Clé API Anthropic de l'app, utilisée pour les visiteurs sans clé perso.
# NE JAMAIS commiter la vraie valeur dans git.
ANTHROPIC_API_KEY=sk-ant-...

# Nombre de leçons gratuites par visiteur et par jour.
DAILY_QUOTA=5

# UPSTASH_REDIS_REST_URL et UPSTASH_REDIS_REST_TOKEN sont injectées
# automatiquement par Vercel quand tu connectes une base Redis (Upstash)
# au projet depuis l'onglet "Storage" — pas besoin de les définir à la main.
